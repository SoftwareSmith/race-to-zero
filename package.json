{
  "name": "race-to-zero",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "homepage": "https://SoftwareSmith.github.io/race-to-zero/",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "node --import tsx ./node_modules/eslint/bin/eslint.js .",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "preview": "vite preview",
    "sync:linear": "tsx scripts/fetch-linear.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:qa": "playwright test tests/e2e",
    "test:qa:headed": "playwright test --headed tests/e2e"
  },
  "dependencies": {
    "@dimforge/rapier2d-compat": "^0.19.3",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "date-fns": "^4.1.0",
    "pixi.js": "^8.17.1",
    "react": "^19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.4",
    "vitest": "^4.1.3"
  }
}
